        G["stages[] subgraph DAG replay<br/>vision → encoder → action / VLM+AE split<br/>cross-stream: pre-created events, alloc-free tick"]
        L1 --> G
        L2 --> G
    end
    subgraph OUT["outputs"]
        O1["actions: raw window readback<br/>or get_output unnormalize"]
    end
    subgraph WARM["warm phase (outside the tick)"]
        W1["prepare(graph, key)<br/>shape-bucket variant capture · evict at safe points only"]
    end
    S1 --> L1
    S2 --> L2
    G --> O1
    WARM -.-> G
